__pycache__/
*.pyc
.pytest_cache/
build/
dist/
*.egg-info/
.venv/
venv/

# Configurations locales contenant les référentiels internes (non versionnées)
config/*.local.yaml
config/*.local.yml

# Mémoire Claude contenant des données internes (non versionnée)
CLAUDE.local.md

# Mode opératoire interne (non versionné)
Comment_faire_une_situation.md

# Données comptables : jamais dans le dépôt
*.xlsx
*.xlsb
*.txt
!requirements*.txt
!tests/**

# Réaffirme l'exclusion des caches Python sous tests/ (annulée par !tests/**)
tests/**/__pycache__/
tests/**/*.pyc
